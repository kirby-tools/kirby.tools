{
  "name": "kirby-tools-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{css,html,json,md,mjs,ts,vue,yml}\" --write",
    "format:check": "prettier \"**/*.{css,html,json,md,mjs,ts,vue,yml}\" --check",
    "test:types": "vue-tsc -b --noEmit",
    "logo-soup:metrics": "logo-soup --output=\"app/data/logo-metrics.json\" public/img/brands",
    "prepare": "nuxt prepare && pnpm run logo-soup:metrics"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.83",
    "@iconify-json/vscode-icons": "^1.2.50",
    "@nuxt/content": "^3.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.8.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sitemap": "^8.0.15",
    "@paddle/paddle-js": "^1.6.4",
    "@takumi-rs/core": "^1.3.0",
    "@takumi-rs/wasm": "^1.3.0",
    "@types/node": "^24.12.4",
    "@vueuse/nuxt": "^14.3.0",
    "ansis": "^4.3.0",
    "eslint": "^10.4.0",
    "logo-soup": "^0.2.3",
    "motion-v": "^2.2.1",
    "nuxt": "^4.4.6",
    "nuxt-og-image": "^6.5.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.1"
  }
}
